{
  "include": ["**/*.ts", "**/*.tsx", "../../packages/shared/src/**/*.ts", "../../packages/shared/src/**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "#/*": ["./src/*"],
      "@/lib/*": ["../../packages/shared/src/lib/*"],
      "@/types/*": ["../../packages/shared/src/types/*"],
      "@/components/ui/*": ["../../packages/shared/src/components/ui/*"],
      "@/components/ui": ["../../packages/shared/src/components/ui"],
      "@/*": ["./src/*"],
      "@/components/resume/*": ["../../packages/shared/src/components/resume/*"],
      "@/components/resume": ["../../packages/shared/src/components/resume"],
      "@/components/analytics/*": ["../../packages/shared/src/components/analytics/*"],
      "@/components/analytics": ["../../packages/shared/src/components/analytics"],
      "@/components/providers/*": ["../../packages/shared/src/components/providers/*"],
      "@/components/providers": ["../../packages/shared/src/components/providers"],
      "@/images/*": ["../../packages/shared/src/images/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
