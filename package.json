{
  "name": "portfolio-monorepo",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "yarn workspaces foreach -A -pi run dev",
    "build": "yarn workspaces foreach -A -pt run build",
    "lint": "yarn workspaces foreach -A -pt run lint",
    "test": "yarn workspaces foreach -A -pt run test"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock": "^3.1092.0",
    "@aws-sdk/client-sfn": "^3.1092.0",
    "@aws-sdk/credential-providers": "^3.1092.0",
    "@types/node": "^26",
    "@types/uuid": "^11.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
