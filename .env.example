# Frontend Environment Variables
# Copy this file to .env.local and update with your values

# ============================================
# API Configuration
# ============================================

# Articles API Base URL
# Get this from your CDK deployment outputs:
# Look for: development-WebappApi.ApiUrl
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.eu-west-1.amazonaws.com/api

# Enable file-based fallback during migration/testing
# Set to false when you want to use API exclusively
USE_FILE_FALLBACK=true

# ============================================
# CloudFront Configuration (Optional)
# ============================================

# CloudFront distribution URL for serving images
# Get this after setting up CloudFront for your S3 bucket
# NEXT_PUBLIC_CLOUDFRONT_URL=https://your-distribution.cloudfront.net

# ============================================
# Authentication (Optional)
# ============================================

# API Key if you add authentication
# ARTICLES_API_KEY=your-api-key-here

# ============================================
# AWS Configuration (For Migration Scripts)
# ============================================
# These are used by migration scripts, not the frontend

# AWS Region
# AWS_REGION=eu-west-1

# AWS Profile (from ~/.aws/credentials)
# AWS_PROFILE=dev-account

# DynamoDB Table Name
# TABLE_NAME=webapp-articles-development

# S3 Bucket Name for article images
# BUCKET_NAME=webapp-article-assets-development

# CloudFront Domain (if configured)
# CLOUDFRONT_DOMAIN=your-distribution.cloudfront.net

# Dry Run Mode for migration scripts
# DRY_RUN=false

# ============================================
# Bedrock Consumer Configuration
# ============================================
# These are injected into the K8s pod via Helm values.yaml
# Discoverable via SSM: /bedrock-development/<param-name>

# DynamoDB table for Bedrock AI-generated content
# Alias for DYNAMODB_TABLE_NAME when using the Bedrock content pipeline
# CONTENT_TABLE_NAME=bedrock-development-ai-content

# S3 bucket for Bedrock assets (images, MDX content)
# Used by ImageRequest component in production to render screenshots
# NEXT_PUBLIC_ASSETS_BUCKET_NAME=bedrock-development-kb-data

# S3 key prefix for published MDX articles
# PUBLISHED_PREFIX=published/

# ============================================
# On-Demand Revalidation
# ============================================
# Shared secret between Bedrock Lambda and Next.js for cache purging
# Lambda calls POST /api/revalidate with this secret after publishing
# REVALIDATION_SECRET=your-secret-here

# ============================================
# In-cluster BFF (public-api) — Server-Side Only
# ============================================
# The portfolio is a CONSUMER: /api/chat and (soon) article reads proxy to the
# in-cluster public-api BFF over Kubernetes service DNS. public-api owns the
# Bedrock API key (Secrets Manager) and the RDS connection — the portfolio holds
# NO Bedrock credentials. /api/chat targets public-api's session-aware RAG
# endpoint (/api/chatbot/authenticated), which persists chat history in RDS.
#
# Defaults to the in-cluster DNS below when unset, so it works in the cluster
# with zero config. Set it only for local dev against a reachable public-api.
# PUBLIC_API_URL=http://public-api.public-api:3001

# ============================================
# Grafana Faro RUM (Client-Side Observability)
# ============================================
# Alloy Faro receiver URL — telemetry is sent here from the browser
# Default: https://ops.nelsonlamounier.com/faro/collect
# Set to empty string or NEXT_PUBLIC_FARO_ENABLED=false to disable
# NEXT_PUBLIC_FARO_URL=https://ops.nelsonlamounier.com/faro/collect
# NEXT_PUBLIC_FARO_ENABLED=true

# ============================================
# Admin Authentication (NextAuth.js)
# ============================================
# Required: Secret used for JWT signing (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here

# Required: Base URL for NextAuth.js callbacks
NEXTAUTH_URL=http://localhost:3000

# Admin credentials for the Credentials provider
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# ============================================
# Job Strategist Pipeline (Server-Side Only)
# ============================================
# DynamoDB table for strategist application data
# Discoverable via SSM: /bedrock-dev/strategist-table-name
# STRATEGIST_TABLE_NAME=bedrock-dev-job-strategist

# Lambda function ARN for triggering the strategist pipeline
# Discoverable via SSM: /bedrock-dev/strategist-trigger-function-arn
# STRATEGIST_TRIGGER_ARN=arn:aws:lambda:eu-west-1:XXXXXXXXXXXX:function:bedrock-dev-strategist-trigger
