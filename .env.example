# Frontend Environment Variables
# Copy this file to .env.local and update with your values

# ============================================
# API Configuration
# ============================================

# Articles API Base URL
# Get this from your CDK deployment outputs:
# Look for: development-WebappApi.ApiUrl
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.eu-west-1.amazonaws.com/api

# Enable file-based fallback during migration/testing
# Set to false when you want to use API exclusively
USE_FILE_FALLBACK=true

# ============================================
# CloudFront Configuration (Optional)
# ============================================

# CloudFront distribution URL for serving images
# Get this after setting up CloudFront for your S3 bucket
# NEXT_PUBLIC_CLOUDFRONT_URL=https://your-distribution.cloudfront.net

# ============================================
# Authentication (Optional)
# ============================================

# API Key if you add authentication
# ARTICLES_API_KEY=your-api-key-here

# ============================================
# AWS Configuration (For Migration Scripts)
# ============================================
# These are used by migration scripts, not the frontend

# AWS Region
# AWS_REGION=eu-west-1

# AWS Profile (from ~/.aws/credentials)
# AWS_PROFILE=dev-account

# DynamoDB Table Name
# TABLE_NAME=webapp-articles-development

# S3 Bucket Name for article images
# BUCKET_NAME=webapp-article-assets-development

# CloudFront Domain (if configured)
# CLOUDFRONT_DOMAIN=your-distribution.cloudfront.net

# Dry Run Mode for migration scripts
# DRY_RUN=false

# ============================================
# Bedrock Consumer Configuration
# ============================================
# These are injected into the K8s pod via Helm values.yaml
# Discoverable via SSM: /bedrock-development/<param-name>

# DynamoDB table for Bedrock AI-generated content
# Alias for DYNAMODB_TABLE_NAME when using the Bedrock content pipeline
# CONTENT_TABLE_NAME=bedrock-development-ai-content

# S3 bucket for Bedrock assets (images, MDX content)
# Used by ImageRequest component in production to render screenshots
# NEXT_PUBLIC_ASSETS_BUCKET_NAME=bedrock-development-kb-data

# S3 key prefix for published MDX articles
# PUBLISHED_PREFIX=published/

# ============================================
# On-Demand Revalidation
# ============================================
# Shared secret between Bedrock Lambda and Next.js for cache purging
# Lambda calls POST /api/revalidate with this secret after publishing
# REVALIDATION_SECRET=your-secret-here
